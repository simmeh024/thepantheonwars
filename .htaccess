# Force browsers (mobile in particular) to always revalidate HTML pages
# with the server instead of serving a heuristically-cached copy for hours
# or days. "no-cache" here means "cache it, but check with the server
# every time before using it" -- the server still answers with a cheap
# 304 Not Modified when nothing changed, so this doesn't add real load,
# it just stops stale HTML (with stale script/style version tags baked
# into it) from being served straight out of the phone's local cache.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, private, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Thu, 19 Nov 1981 08:52:00 GMT"
  </FilesMatch>
</IfModule>

# Versioned static assets may be reused for a full year without a revalidation
# request. Every asset change must keep using a new filename or a bumped query
# version; HTML stays no-cache above so clients receive those new URLs
# immediately. Do not extend this policy to PHP/API responses: they are
# dynamic and may be user-specific.
<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|mjs|woff2?|ttf|otf|eot|svg|avif|webp|png|jpe?g|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Baseline security headers, applied site-wide (static pages and PHP API
# responses alike). No Content-Security-Policy here on purpose: this site
# relies on inline <script>/<style> throughout (admin/index.html especially)
# with no build step to add nonces/hashes, so a real CSP would need a
# frontend refactor first -- tracked as a follow-up, not skipped by oversight.
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
