# Redirect the first HTTP visit before HSTS has had a chance to be stored.
# HSTS protects subsequent visits; this redirect closes the bootstrap gap and
# keeps every route and query string on the canonical HTTPS origin.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://thepantheonwars.com%{REQUEST_URI} [R=301,L,NE]
</IfModule>

# Force browsers (mobile in particular) to always revalidate HTML pages
# with the server instead of serving a heuristically-cached copy for hours
# or days. "no-cache" here means "cache it, but check with the server
# every time before using it" -- the server still answers with a cheap
# 304 Not Modified when nothing changed, so this doesn't add real load,
# it just stops stale HTML (with stale script/style version tags baked
# into it) from being served straight out of the phone's local cache.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, private, max-age=0"
    Header set Pragma "no-cache"
    Header set Expires "Thu, 19 Nov 1981 08:52:00 GMT"
  </FilesMatch>
</IfModule>

# Versioned static assets may be reused for a full year without a revalidation
# request. Every asset change must keep using a new filename or a bumped query
# version; HTML stays no-cache above so clients receive those new URLs
# immediately. Do not extend this policy to PHP/API responses: they are
# dynamic and may be user-specific.
<IfModule mod_headers.c>
  <FilesMatch "\.(?:css|js|mjs|woff2?|ttf|otf|eot|svg|avif|webp|png|jpe?g|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header unset Pragma
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Browser security headers, applied site-wide to static pages and PHP API
# responses alike. The CSP intentionally has no `unsafe-inline` script
# exception: every required inline script is pinned by an exact SHA-256 hash.
# When changing an inline script, regenerate its hash and update this policy;
# docs/security-headers.md records the verification command and directives.
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
  Header always set X-XSS-Protection "0"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'sha256-3Wq8ru84oGX8ZkiLNvfKCoYxLZVBeuofJTZr1hTlJrw=' 'sha256-P1c4ZrGVLj2XQcGzfTWSoQe+e7sMHFyPaTOkBGAkZco=' 'sha256-N1JT1Y2yVvX5Axju1NkkM1ie4YAgeBeOHa5NXM03hfs=' 'sha256-UjPCvJ7GPk6YUNW/CybSLYWkewDhxtW3Bg3sLDAS4YU=' 'sha256-7mZvPxyW8Gn7wsKcWk2AFw8lrDeT0P/EoSk1Sj4jlq8=' 'sha256-LxTledPNR4JKofWI4OTAJobHXgrDCI9G85FqONpnwMk=' 'sha256-QRGEMvBrRA7h3Lu2/H70Ip3expgSXKZeLLYggz0g7Wc=' 'sha256-O49MOJiK9rvMcB/3NYWSBVX52tgTeyYxUMsTiLr1WiQ=' 'sha256-uPnyW2VWI1PS6Y4ucWgZei6UmngRmSqUdIFj53LyZ4E=' 'sha256-k2yK521vYfx4G0EFhsxEWWjRsuUKnGMXwR5XGKAzY4w=' 'sha256-vv+tCLGMa7NvwACJhd3KNTVeH8A9jExEBUo20lcR3NY=' 'sha256-ZvkTu7pBK7qIgl+7rz8ohUE3SJy1aQ9+zmKvA/sJreA=' 'sha256-vvyC9ytXte/Vxg4dfYAOv9PL4L2N3Oinsn0Heb3wt9w=' 'sha256-STC+Rfaz7vGIPza9fCclStnozszC70JbiVdgUfk/emY=' 'sha256-urUB7TImvVDQGCXO7BUcHPaAo4lPnEC57gBviRvfR2w=' 'sha256-CcGhyegPDG4CBYgmOUWsPQSCY1BlivLBX2hjLHsKnd4=' 'sha256-QZ7NJ4Je359xf4vc3mRyqIW2waKdA5nVg5Xq5LrjPww=' 'sha256-r04I3YbYzKpiM6ndkah6uIX4/+04dMCPvvrxGPngmD0=' 'sha256-wyBNL7V/2gXBv1iH0R4SJea2aFOijd8tsYqgFZtxdYg=' 'sha256-HTy0szLbQNXuShcUEtPA4FefCxS5dcSu3OVt1OlMbcc=' 'sha256-m9n3DwPGXgvmbtOyZxFxTeY/5HXyzYNb8UFOW919mhk=' 'sha256-3n4V9C/oGhjlGqqnJtzWqPRw2p6odv6Sq200DGqNV54='; script-src-attr 'unsafe-hashes' 'sha256-1jAmyYXcRq6zFldLe/GCgIDJBiOONdXjTLgEFMDnDSM='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: http:; connect-src 'self'; frame-src https://open.spotify.com; media-src 'self'; manifest-src 'self'; worker-src 'self'"
</IfModule>
